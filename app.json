{
  "expo": {
    "name": "depay",
    "slug": "depayapp",
    "scheme": "depay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/depay.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/depay.png",
      "resizeMode": "cover",
      "backgroundColor": "#fff"
    },
    "fonts": [
      "./assets/fonts/Tinos-Regular.ttf",
      "./assets/fonts/Tinos-Bold.ttf",
      "./assets/fonts/Tinos-Italic.ttf",
      "./assets/fonts/Tinos-BoldItalic.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olamide00.depay"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/depay.png",
        "backgroundColor": "#fff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.olamide00.depay",
      "permissions": [
        "android.permission.GET_ACCOUNTS",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/images/DEPAYLOGO.png.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser",
      "expo-build-properties",
      "expo-font",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Allow JAAN to use Face ID to log you in." }
      ]
    ]
  }
}
